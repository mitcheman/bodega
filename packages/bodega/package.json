{
  "name": "@mitcheman/bodega",
  "version": "0.3.1",
  "description": "Bodega SDK — commerce storefront + merchant admin + auth + route handlers for Next.js App Router stores. The code powering the mitcheman/bodega Claude Code plugin.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitcheman/bodega.git",
    "directory": "packages/bodega"
  },
  "homepage": "https://github.com/mitcheman/bodega#readme",
  "bugs": {
    "url": "https://github.com/mitcheman/bodega/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./storage": {
      "types": "./dist/storage/blob.d.ts",
      "import": "./dist/storage/blob.js",
      "default": "./dist/storage/blob.js"
    },
    "./auth": {
      "types": "./dist/auth/magic-link.d.ts",
      "import": "./dist/auth/magic-link.js",
      "default": "./dist/auth/magic-link.js"
    },
    "./auth/session": {
      "types": "./dist/auth/session.d.ts",
      "import": "./dist/auth/session.js",
      "default": "./dist/auth/session.js"
    },
    "./routes/cart": {
      "types": "./dist/routes/cart.d.ts",
      "import": "./dist/routes/cart.js",
      "default": "./dist/routes/cart.js"
    },
    "./routes/cart-items": {
      "types": "./dist/routes/cart-items.d.ts",
      "import": "./dist/routes/cart-items.js",
      "default": "./dist/routes/cart-items.js"
    },
    "./routes/checkout": {
      "types": "./dist/routes/checkout.d.ts",
      "import": "./dist/routes/checkout.js",
      "default": "./dist/routes/checkout.js"
    },
    "./routes/stripe-webhook": {
      "types": "./dist/routes/stripe-webhook.d.ts",
      "import": "./dist/routes/stripe-webhook.js",
      "default": "./dist/routes/stripe-webhook.js"
    },
    "./routes/auth-login": {
      "types": "./dist/routes/auth-login.d.ts",
      "import": "./dist/routes/auth-login.js",
      "default": "./dist/routes/auth-login.js"
    },
    "./routes/auth-verify": {
      "types": "./dist/routes/auth-verify.d.ts",
      "import": "./dist/routes/auth-verify.js",
      "default": "./dist/routes/auth-verify.js"
    },
    "./routes/auth-logout": {
      "types": "./dist/routes/auth-logout.d.ts",
      "import": "./dist/routes/auth-logout.js",
      "default": "./dist/routes/auth-logout.js"
    },
    "./routes/auth-magic-link": {
      "types": "./dist/routes/auth-magic-link.d.ts",
      "import": "./dist/routes/auth-magic-link.js",
      "default": "./dist/routes/auth-magic-link.js"
    },
    "./routes/products": {
      "types": "./dist/routes/products.d.ts",
      "import": "./dist/routes/products.js",
      "default": "./dist/routes/products.js"
    },
    "./routes/orders": {
      "types": "./dist/routes/orders.d.ts",
      "import": "./dist/routes/orders.js",
      "default": "./dist/routes/orders.js"
    },
    "./routes/upload": {
      "types": "./dist/routes/upload.d.ts",
      "import": "./dist/routes/upload.js",
      "default": "./dist/routes/upload.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "next": ">=15"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.0.0",
    "@stripe/react-stripe-js": "^3.0.0",
    "@vercel/blob": "^2.3.3",
    "resend": "^4.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "commerce",
    "storefront",
    "admin",
    "merchant",
    "stripe",
    "nextjs",
    "react",
    "ecommerce",
    "bodega"
  ]
}
