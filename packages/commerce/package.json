{
  "name": "@bodega/commerce",
  "version": "0.1.0",
  "description": "Commerce components for Bodega stores. TypeScript library for Next.js App Router: ProductGrid, ProductPage, Cart, Checkout, plus route handlers and Vercel Blob storage. Themeable via CSS custom properties.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./storage": {
      "types": "./dist/storage/blob.d.ts",
      "import": "./dist/storage/blob.js"
    },
    "./routes/cart": {
      "types": "./dist/routes/cart.d.ts",
      "import": "./dist/routes/cart.js"
    },
    "./routes/cart-items": {
      "types": "./dist/routes/cart-items.d.ts",
      "import": "./dist/routes/cart-items.js"
    },
    "./routes/checkout": {
      "types": "./dist/routes/checkout.d.ts",
      "import": "./dist/routes/checkout.js"
    },
    "./routes/stripe-webhook": {
      "types": "./dist/routes/stripe-webhook.d.ts",
      "import": "./dist/routes/stripe-webhook.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "next": ">=15"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.0.0",
    "@stripe/react-stripe-js": "^3.0.0",
    "@vercel/blob": "^1.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "commerce",
    "storefront",
    "stripe",
    "nextjs",
    "react",
    "ecommerce"
  ]
}
