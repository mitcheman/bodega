{
  "name": "@bodega/commerce",
  "version": "0.0.1",
  "description": "Commerce components for Bodega stores. Framework-agnostic TypeScript library: ProductGrid, ProductPage, Cart, Checkout. Themeable via CSS custom properties. Currently: types + theme resolver (components in progress).",
  "license": "Apache-2.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not yet implemented'"
  }
}
