{
  "name": "@bodega/studio",
  "version": "0.1.0",
  "description": "Merchant-facing admin UI for Bodega stores. Mountable at /studio with magic-link auth. Phone-first. Product CRUD, order fulfillment, session cookies.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/magic-link.d.ts",
      "import": "./dist/auth/magic-link.js"
    },
    "./auth/session": {
      "types": "./dist/auth/session.d.ts",
      "import": "./dist/auth/session.js"
    },
    "./routes/auth-login": {
      "types": "./dist/routes/auth-login.d.ts",
      "import": "./dist/routes/auth-login.js"
    },
    "./routes/auth-verify": {
      "types": "./dist/routes/auth-verify.d.ts",
      "import": "./dist/routes/auth-verify.js"
    },
    "./routes/auth-logout": {
      "types": "./dist/routes/auth-logout.d.ts",
      "import": "./dist/routes/auth-logout.js"
    },
    "./routes/auth-magic-link": {
      "types": "./dist/routes/auth-magic-link.d.ts",
      "import": "./dist/routes/auth-magic-link.js"
    },
    "./routes/products": {
      "types": "./dist/routes/products.d.ts",
      "import": "./dist/routes/products.js"
    },
    "./routes/orders": {
      "types": "./dist/routes/orders.d.ts",
      "import": "./dist/routes/orders.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "next": ">=15"
  },
  "dependencies": {
    "@bodega/commerce": "workspace:^",
    "@vercel/blob": "^1.0.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "admin",
    "merchant",
    "stripe",
    "nextjs",
    "auth",
    "magic-link"
  ]
}
